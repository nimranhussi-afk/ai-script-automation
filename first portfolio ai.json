    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// 1. Grab the raw text string from the AI output\nlet rawText = $json.output;\n\n// 2. Clean out any markdown wrappers if the AI snuck them in\nif (rawText.includes(\"```json\")) {\n    rawText = rawText.split(\"```json\")[1].split(\"```\")[0];\n} else if (rawText.includes(\"```\")) {\n    rawText = rawText.split(\"```\")[1].split(\"```\")[0];\n}\n// This forces n8n to only pass the very first row down the stream\n\n\n// 3. Convert the raw string into an actual JavaScript Object\nconst cleanedData = JSON.parse(rawText.trim());\n\n// 4. Return clean, distinct keys to n8n\nreturn {\n    scriptText: cleanedData.scriptText,\n    imagePrompt: cleanedData.imagePrompt\n};"
      },
